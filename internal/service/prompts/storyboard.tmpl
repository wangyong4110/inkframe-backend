      "shot_size": "景别（极端特写/特写/中景/全景/远景）",
      "duration": 2.5,
      "camera_movement": "镜头运动（静态/推拉摇移/跟拍/升降）",
      "angle": "拍摄角度（平视/俯视/仰视/荷兰角）",
      "description": "画面描述（中文）",
      "dialogue": "对话内容（如有）",
      "emotion": "情感基调",
      "transition": "转场方式（硬切/淡入淡出/溶解/划像等）",
      "lighting": "光源方向和类型（如：侧逆光、黄昏暖光）",
      "color_palette": "色调描述（如：冷蓝色调、暖金色调）",
      "visual_prompt": "professional photo, [subject], [setting], [art style] style, [lighting], [composition], highly detailed, 4k resolution",
